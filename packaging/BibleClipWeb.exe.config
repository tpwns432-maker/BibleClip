<?xml version="1.0" encoding="utf-8"?>
<!--
  BibleClipWeb.exe.config — shipped next to the exe.

  loadFromRemoteSources: when BibleClip is run from a DOWNLOADED zip, every
  extracted file (incl. the bundled pythonnet Python.Runtime.dll) carries the
  Mark-of-the-Web ("from the Internet"). By default .NET Framework refuses to
  load such "remote" assemblies → pywebview→pythonnet CLR init fails with
  "Failed to resolve Python.Runtime.Loader.Initialize". Enabling this lets the
  hosted CLR load them with full trust. Backstop for app._strip_motw() (which
  clears the tag directly but can't when the install folder is read-only).
-->
<configuration>
  <runtime>
    <loadFromRemoteSources enabled="true"/>
  </runtime>
</configuration>
